{
  "version": 8,
  "name": "DriveLink Satellite",
  "sources": {
    "satellite": {
      "type": "raster",
      "tiles": ["https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}"],
      "tileSize": 256,
      "maxzoom": 18
    },
    "protomaps": {
      "type": "vector",
      "tiles": ["https://api.protomaps.com/tiles/v4/{z}/{x}/{y}.mvt?key=c35e41de17ff0820"],
      "maxzoom": 15
    }
  },
  "glyphs": "https://protomaps.github.io/basemaps-assets/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "satellite-tiles",
      "type": "raster",
      "source": "satellite"
    },
    {
      "id": "roads_label_major",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "motorway", "trunk", "primary"],
      "minzoom": 10,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Medium"],
        "text-size": {"stops": [[10, 10], [14, 13]]},
        "symbol-placement": "line",
        "text-rotation-alignment": "map"
      },
      "paint": {
        "text-color": "#FFFFFF",
        "text-halo-color": "#000000",
        "text-halo-width": 2
      }
    },
    {
      "id": "roads_label_secondary",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "secondary", "tertiary"],
      "minzoom": 13,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": {"stops": [[13, 10], [16, 12]]},
        "symbol-placement": "line",
        "text-rotation-alignment": "map"
      },
      "paint": {
        "text-color": "#FFFFFF",
        "text-halo-color": "#000000",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "roads_label_minor",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "residential", "living_street", "unclassified"],
      "minzoom": 15,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": 10,
        "symbol-placement": "line",
        "text-rotation-alignment": "map"
      },
      "paint": {
        "text-color": "#E0E0E0",
        "text-halo-color": "#000000",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "places_country",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["==", "kind", "country"],
      "minzoom": 2,
      "maxzoom": 15,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Medium"],
        "text-size": {"stops": [[2, 11], [6, 18]]},
        "text-transform": "uppercase",
        "text-letter-spacing": 0.1,
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#FFFFFF",
        "text-halo-color": "#000000",
        "text-halo-width": 2
      }
    },
    {
      "id": "places_state",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["==", "kind", "state"],
      "minzoom": 4,
      "maxzoom": 15,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": {"stops": [[4, 9], [8, 14]]},
        "text-transform": "uppercase",
        "text-letter-spacing": 0.08
      },
      "paint": {
        "text-color": "#E0E0E0",
        "text-halo-color": "#000000",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "places_city",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["==", "kind", "city"],
      "minzoom": 5,
      "maxzoom": 15,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Medium"],
        "text-size": {"stops": [[5, 11], [10, 17], [14, 22]]},
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#FFFFFF",
        "text-halo-color": "#000000",
        "text-halo-width": 2
      }
    },
    {
      "id": "places_town",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["==", "kind", "town"],
      "minzoom": 8,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": {"stops": [[8, 10], [13, 15]]},
        "text-max-width": 7
      },
      "paint": {
        "text-color": "#FFFFFF",
        "text-halo-color": "#000000",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "places_village",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["in", "kind", "village", "hamlet"],
      "minzoom": 11,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": {"stops": [[11, 9], [15, 13]]},
        "text-max-width": 6
      },
      "paint": {
        "text-color": "#E0E0E0",
        "text-halo-color": "#000000",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "water_label",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "water",
      "minzoom": 8,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Italic"],
        "text-size": {"stops": [[8, 10], [14, 15]]},
        "text-max-width": 6
      },
      "paint": {
        "text-color": "#80D0FF",
        "text-halo-color": "#000000",
        "text-halo-width": 1.5
      }
    }
  ]
}